[build-system]
requires = ["pdm-backend"]
build-backend = "pdm.backend"

{%- block BuildConfig -%}
{# Override this block for specific build configuration #}
{%- endblock BuildConfig %}

[project]
name = "{{repo.name | replace('.', '-')}}"
authors = [{{ '{' }}name = "{{ repo.owner }}", email="{{ repo.email }}"{{ '}' }}]
maintainers = [{{ '{' }} name = "{{ repo.owner }}", email="{{ repo.email }}" {{ '}' }}]
description = "{{ repo.description }}"
readme = {{ '{' }}file="README.md", content-type = "text/markdown"{{ '}' }}
keywords = []
requires-python = '>={{ python_version | default("3.11.0") }}'
classifiers = [
        "Environment :: Console",
        "Topic :: Software Development :: Libraries :: Python Modules",
        "Programming Language :: Python :: 3",
        "Programming Language :: Python :: 3.12",
        "Intended Audience :: Developers",
    	"License :: OSI Approved :: MIT License",
        "Operating System :: Microsoft :: Windows",
        "Operating System :: POSIX :: Linux",
        "Operating System :: MacOS :: MacOS X",
        "Natural Language :: English"
        # "Development Status :: 6 - Mature"
]
dependencies = [
{% block Dependencies %}
{% endblock Dependencies %}
]
dynamic = ["version"]

[dependency-groups]

test = [
  "pytest>=8.3.3",
  "pytest-cov>=6.0.0",
  "pytest-subtests>=0.4.0",
  "coverage>=7.9.1",
]

lint = [
  "ruff>=0.7.4",
  "isort>=5.13.2",
]

types = [
  "mypy>=0.910",
  "lxml>=5.3.0",
]

security = [
  "bandit>=1.7.10",
]

licenses = [
  "licensecheck>=2024.3",
]

docs = [
  "mike>=2.1.3",
  "mkdocs-autorefs>=1.2.0",
  "mkdocs>=1.6.1",
  "mkdocs-git-authors-plugin>=0.9.2",
  "mkdocs-git-revision-date-localized-plugin>=1.3.0",
  "mkdocs-github-changelog>=0.1.0",
  "mkdocs-include-markdown-plugin>=7.1.2",
  "mkdocs-material>=9.5.46",
  "mkdocs-include-dir-to-nav>=1.2.0",
  "mkdocstrings[python]>=0.26.1",
  "mkdocs-coverage>=1.1.0",
  "mkdocs-licenseinfo>=0.1.0",
]

{% raw %}
dev = [
  "ipykernel>=6.29.5",
  "ipdb>=0.13.3",
  "ipython>=8.2.0",
  "nox",
  "pre-commit>=4.2.0",
  {include-group = "test"},
  {include-group = "lint"},
  {include-group = "types"},
  {include-group = "security"},
  {include-group = "licenses"},
  {include-group = "docs"},
]
{% endraw %}

[project.optional-dependencies]

[project.urls]
repository = "{{ repo.url }}"

[project.scripts]

{% block EntryPoints %}
{% endblock EntryPoints %}

# Tools



{% block CustomUvIndex %}
# [[tool.uv.index]]
# name = "..."
# url = "https://.../pypi/python/simple"
# publish-url = "https://.../pypi/python/"

{% endblock CustomUvIndex %}

[tool.uv]
package = true

[tool.pdm]
distribution = true

[tool.pdm.build]
includes = ["src/"]

[tool.pdm.version]
source = "scm"
write_to = "{{ repo.src_path }}/_version.py"
write_template = "__version__ = '{{ '{' }}{{ '}' }}'"
fallback_version = "0.0.0"


[tool.mypy]
python_version = "3.11"
show_error_codes = true
strict = true
{% raw %}
overrides = [
  { module = [
    "virtualenv.*",
    "tox.*",
    "importlib_metadata.*",
{% endraw %}
    "{{ repo.name }}._version"
  ], ignore_missing_imports = true {{ '}' }},
]


[tool.isort]
profile = "black"
src_paths = ['src/']
known_first_party = [
    "{{repo.py_root}}.*"
]

known_application = '{{repo.py_name}}*'
force_alphabetical_sort_within_sections = true
force_sort_within_sections = true
reverse_relative = true
combine_as_imports = true
sections = ["FUTURE", "STDLIB", "THIRDPARTY", "FIRSTPARTY", "APPLICATION", "LOCALFOLDER"]
